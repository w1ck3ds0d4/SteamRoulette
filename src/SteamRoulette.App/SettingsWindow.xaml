<Window x:Class="SteamRoulette.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="330" Width="500" Icon="app.ico"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#0F1218" Foreground="#C7D5E0" FontFamily="Segoe UI" FontSize="13">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#161B24"/>
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="BorderBrush" Value="#2A3342"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="7,5"/>
            <Setter Property="CaretBrush" Value="#C7D5E0"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#1B2230"/>
            <Setter Property="Foreground" Value="#C7D5E0"/>
            <Setter Property="BorderBrush" Value="#2A3342"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Steam Web API key (optional)" Foreground="#8F98A0"/>
        <TextBox Grid.Row="1" x:Name="KeyBox"/>

        <TextBlock Grid.Row="2" Text="Your SteamID (64-bit, optional)" Foreground="#8F98A0" Margin="0,14,0,0"/>
        <TextBox Grid.Row="3" x:Name="SteamIdBox"/>

        <StackPanel Grid.Row="4" Margin="0,16,0,0">
            <TextBlock TextWrapping="Wrap" Foreground="#8F98A0">
                Without these, only <Run FontWeight="SemiBold">installed</Run> games are listed. Add them to roulette
                your whole owned library with playtime-based filters.
            </TextBlock>
            <TextBlock Margin="0,10,0,0">
                <Hyperlink NavigateUri="https://steamcommunity.com/dev/apikey" RequestNavigate="Link_Navigate"
                           Foreground="#66C0F4">Get an API key</Hyperlink>
                <Run Foreground="#8F98A0">  ·  </Run>
                <Hyperlink NavigateUri="https://steamid.io" RequestNavigate="Link_Navigate"
                           Foreground="#66C0F4">Find your SteamID</Hyperlink>
            </TextBlock>
        </StackPanel>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Click="Cancel_Click"/>
            <Button Content="Save" Click="Save_Click"
                    Background="#1A9FFF" Foreground="White" BorderBrush="#1A9FFF"/>
        </StackPanel>
    </Grid>
</Window>
