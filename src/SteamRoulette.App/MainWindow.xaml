<Window x:Class="SteamRoulette.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Steam Roulette" Height="640" Width="960"
        MinHeight="520" MinWidth="760"
        WindowStartupLocation="CenterScreen"
        Background="#0F1218" Foreground="#C7D5E0"
        FontFamily="Segoe UI" FontSize="13">

    <Window.Resources>
        <Style TargetType="Button" x:Key="Chip">
            <Setter Property="Background" Value="#1B2230"/>
            <Setter Property="Foreground" Value="#C7D5E0"/>
            <Setter Property="BorderBrush" Value="#2A3342"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#243042"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="Primary" BasedOn="{StaticResource Chip}">
            <Setter Property="Background" Value="#1A9FFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#1A9FFF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#33ACFF"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#C7D5E0"/>
            <Setter Property="Margin" Value="0,0,16,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#161B24"/>
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="BorderBrush" Value="#2A3342"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="CaretBrush" Value="#C7D5E0"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="Muted">
            <Setter Property="Foreground" Value="#8F98A0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,14">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="🎲" FontSize="22" Margin="0,0,8,0"/>
                <TextBlock Text="Steam Roulette" FontSize="20" FontWeight="SemiBold" Foreground="#E6EDF3"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="↻  Reload" Style="{StaticResource Chip}" Margin="0,0,8,0"
                        IsEnabled="{Binding NotBusy}" Click="Reload_Click"/>
                <Button Content="⚙  Settings" Style="{StaticResource Chip}" Click="Settings_Click"/>
            </StackPanel>
        </Grid>

        <!-- Filters -->
        <Border Grid.Row="1" Background="#141A24" BorderBrush="#222C3A" BorderThickness="1"
                CornerRadius="8" Padding="14,12" Margin="0,0,0,14">
            <WrapPanel Orientation="Horizontal">
                <CheckBox Content="Installed only" IsChecked="{Binding InstalledOnly}"/>
                <CheckBox Content="Unplayed only" IsChecked="{Binding UnplayedOnly}"/>
                <CheckBox Content="Favor my backlog" IsChecked="{Binding WeightTowardBacklog}"
                          ToolTip="Weight the roll toward games with little playtime"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,16,0" VerticalAlignment="Center">
                    <TextBlock Text="Max hours" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox Width="52" Text="{Binding MaxHoursText, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,16,0" VerticalAlignment="Center">
                    <TextBlock Text="Hide played in last (days)" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox Width="52" Text="{Binding ExcludeDaysText, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                    <TextBlock Text="Search" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox Width="140" Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                    <TextBlock Text="Genre" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox Width="150" ItemsSource="{Binding Genres}" SelectedItem="{Binding Genre}"
                              Background="#161B24" Foreground="#E6EDF3"/>
                </StackPanel>
                <CheckBox Content="Has achievements" IsChecked="{Binding RequireAchievements}"/>
                <CheckBox Content="Unfinished achievements" IsChecked="{Binding OnlyIncomplete}"
                          ToolTip="Only games with achievements you haven't 100%-ed yet"/>
            </WrapPanel>
        </Border>

        <!-- Main: pick card + list -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: roulette + result -->
            <Border Grid.Column="0" Background="#141A24" BorderBrush="#222C3A" BorderThickness="1"
                    CornerRadius="10" Padding="18" Margin="0,0,14,0">
                <DockPanel>
                    <Button DockPanel.Dock="Top" Content="🎲  Surprise me" Style="{StaticResource Primary}"
                            FontSize="16" Padding="12,14" Click="Spin_Click"/>

                    <Button DockPanel.Dock="Bottom" Content="▶  Launch in Steam" Style="{StaticResource Primary}"
                            Margin="0,14,0,0" Padding="12,12" Click="Launch_Click"
                            IsEnabled="{Binding HasPick}"/>

                    <Border Margin="0,16,0,0" Background="#0C0F15" CornerRadius="8" SnapsToDevicePixels="True">
                        <Grid>
                            <Image Source="{Binding Picked.HeaderImageUrl}" Stretch="Uniform" VerticalAlignment="Top"/>
                            <StackPanel VerticalAlignment="Bottom" Background="#CC0C0F15">
                                <TextBlock Text="{Binding PickedTitle}" FontSize="17" FontWeight="SemiBold"
                                           Foreground="#FFFFFF" TextWrapping="Wrap" Margin="14,12,14,2"/>
                                <TextBlock Text="{Binding PickedSubtitle}" Style="{StaticResource Muted}"
                                           Margin="14,0,14,12"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DockPanel>
            </Border>

            <!-- Right: filtered library -->
            <Border Grid.Column="1" Background="#141A24" BorderBrush="#222C3A" BorderThickness="1" CornerRadius="10">
                <DockPanel Margin="2">
                    <DockPanel DockPanel.Dock="Top" Margin="14,10,14,8">
                        <TextBlock Text="{Binding EnrichStatus}" DockPanel.Dock="Right" Foreground="#66C0F4"/>
                        <TextBlock Text="{Binding CountText}" Style="{StaticResource Muted}"/>
                    </DockPanel>
                    <ListView x:Name="GamesList" ItemsSource="{Binding Games}" Background="Transparent"
                              BorderThickness="0" Foreground="#C7D5E0"
                              MouseDoubleClick="GamesList_DoubleClick"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Game" Width="320"
                                                DisplayMemberBinding="{Binding Name}"/>
                                <GridViewColumn Header="Hours" Width="80"
                                                DisplayMemberBinding="{Binding PlaytimeHours, StringFormat={}{0:0.0}}"/>
                                <GridViewColumn Header="Installed" Width="80"
                                                DisplayMemberBinding="{Binding InstalledMark}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Status bar -->
        <TextBlock Grid.Row="3" Margin="0,14,0,0" Text="{Binding Status}" Style="{StaticResource Muted}"/>
    </Grid>
</Window>
